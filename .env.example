# FFmpeg encoder: "h264_nvenc" (GPU) or "libx264" (CPU)
FFMPEG_ENCODER=h264_nvenc
# NVENC: p1-p7 (p4 recommended) | x264: ultrafast/fast/medium/slow
FFMPEG_PRESET=p4

# S3 credentials (for uploading transcoded files)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_REGION=auto

# Webhook auth (Video Hub sends this to authenticate requests)
WEBHOOK_SECRET=

# Docker Compose
TRANSCODER_DOMAIN=transcoder.lms
TRANSCODER_BASE=cpu
TRAEFIK_ENTRYPOINTS=web
TRAEFIK_TLS_LABEL=traefik.enable=true

# Parallel encoding (matches NVENC units: RTX 5090=3, RTX 4090=2, RTX 3090=1)
TRANSCODE_PARALLEL=3
